          },
          {
            "name": "maxPrice",
            "required": false,
            "in": "query",
            "schema": {
              "example": 50000000,
              "type": "number"
            }
          },
          {
            "name": "sortBy",
            "required": false,
            "in": "query",
            "schema": {
              "default": "createdAt",
              "type": "string",
              "enum": [
                "price",
                "name",
                "createdAt"
              ]
            }
          },
          {
            "name": "order",
            "required": false,
            "in": "query",
            "schema": {
              "default": "desc",
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Get all products with search/filter/sort/pagination",
        "tags": [
          "Products"
        ]
