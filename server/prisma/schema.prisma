generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  password     String
  phone        String?
  name         String
  role         Int       @default(1)
  refreshToken String?
  createdAt    DateTime  @default(now())
  address      String?
  updatedAt    DateTime? @updatedAt
  orders       Orders[]
}

model Product {
  id              Int      @id @default(autoincrement())
  name            String
  type            String
  description     String
  price           Int
  discountPercent Int?
  images          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Orders[]
}

model Orders {
  id        Int      @id @default(autoincrement())
  quantity  Int
  status    Boolean
  createdAt DateTime @default(now())
  productId Int
  userId    Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
